# .env.example — wa-voicenote-triage environment variables
#
# Copy this file to ~/.config/wa-voicenote/secrets.env (mode 600, outside the
# repo) for local development. NEVER commit a file with real values to git.
#
# In production these are set on the Container App via:
#   az containerapp update --set-env-vars KEY=value
#   az containerapp secret set --name <app> --secrets name=value
# See infra/README.md for the full layout.

# -----------------------------------------------------------------------------
# REQUIRED — Twilio
# -----------------------------------------------------------------------------
# Twilio Account SID. Must begin with "AC".
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token (Basic auth password for the REST API and webhook signing).
# Wrapped as SecretStr in the app; never logged.
TWILIO_AUTH_TOKEN=replace_me

# The "From" number for outbound WhatsApp. Sandbox sender is
# whatsapp:+14155238886. Must start with "whatsapp:+".
TWILIO_FROM=whatsapp:+14155238886

# Comma-separated list of E.164 numbers prefixed with "whatsapp:+" that are
# allowed to message the bot. Anyone else is dropped silently with an empty
# TwiML response.
TWILIO_ALLOWLIST=whatsapp:+34611779374

# -----------------------------------------------------------------------------
# REQUIRED — Azure OpenAI
# -----------------------------------------------------------------------------
# AOAI account endpoint. The trailing slash is auto-appended if missing.
AZURE_OPENAI_ENDPOINT=https://your-aoai-resource.openai.azure.com/

# The deployment name created in the AOAI Foundry. Must be a deployment of an
# audio-capable model (gpt-audio-mini, gpt-audio, or gpt-audio-1.5).
AZURE_OPENAI_DEPLOYMENT=gpt-audio-mini

# -----------------------------------------------------------------------------
# REQUIRED — Azure Storage
# -----------------------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=stwavoicenote
AZURE_STORAGE_TABLE=convstate
AZURE_STORAGE_CONTAINER=audio-staging

# -----------------------------------------------------------------------------
# REQUIRED — LLM system prompt (single line)
# -----------------------------------------------------------------------------
# The system prompt sent with every AOAI call. Must instruct the model to
# return a JSON object with the three keys transcript, summary,
# suggested_reply. See docs/PLAN.md §10.4 for the production prompt.
LLM_SYSTEM_PROMPT=You are a Meta-Cognitive Reasoning Expert. Receive a voice note and optional context. Detect the language. Return a single JSON object with keys "transcript" (verbatim in detected language), "summary" (concise, detected language), "suggested_reply" (in detected language, concise and direct, no emojis or filler). Output JSON only. No prose, no markdown fences.

# -----------------------------------------------------------------------------
# OPTIONAL — Auth & telemetry
# -----------------------------------------------------------------------------
# When set, AOAI uses api-key auth (local dev). When unset, the app uses
# DefaultAzureCredential (Managed Identity in prod, az login locally).
AZURE_OPENAI_API_KEY=

# Application Insights connection string. When unset, telemetry is disabled
# gracefully — logs still print to stdout as JSON, but nothing ships to App
# Insights. SecretStr-wrapped in the app.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Bearer token for the /diag endpoint. When unset, /diag returns 503. Generate
# with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DIAG_TOKEN=

# -----------------------------------------------------------------------------
# OPERATIONAL KNOBS (defaults shown — all overridable via env)
# -----------------------------------------------------------------------------
# OpenAI API version. 2025-04-01-preview or later supports input_audio.
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Comma-separated language codes. Informational — the LLM auto-detects.
EXPECTED_LANGUAGES=ES,EN,DE

# Passive timeout for the awaiting_context state. If the user sends a voice
# note but never sends context/"no" within this many seconds, the stale audio
# is discarded on the next inbound message.
CONTEXT_TIMEOUT_SECONDS=120

# Policy for the suggested_reply language. Currently "match_inbound" (return
# the suggested reply in the same language as the voice note).
LANGUAGE_POLICY=match_inbound

# Number of most-recent Twilio MessageSids per phone kept in the dedup ring.
IDEMPOTENCY_RING_SIZE=100

# Outbound HTTP timeout in seconds. AOAI on 5+ minute audio can take 60-90s,
# so this is generous. Lower it for testing if needed.
HTTP_TIMEOUT_SECONDS=180

# Max completion tokens the AOAI call may produce. Below ~1000 truncates
# multi-minute transcripts mid-string and breaks JSON parsing.
AOAI_MAX_TOKENS=4000

# Twilio's hard limit per WhatsApp message is 1600 characters; this is the
# soft cap we split chunks at (we reserve 16 chars for the "(i/N) " marker).
WHATSAPP_MAX_CHARS_PER_MESSAGE=1500

# Log level. One of DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# OpenTelemetry service.name resource attribute (used by App Insights).
OTEL_SERVICE_NAME=wa-voicenote-triage

# Free-form deployment tag for telemetry. Suggested values: local, dev, prod.
ENV_NAME=local

# -----------------------------------------------------------------------------
# USER-FACING MESSAGE TEMPLATES (defaults shown)
# -----------------------------------------------------------------------------
MSG_ACK_RECEIVED=Voice note received. Reply with extra context, or send 'no' to skip.
MSG_REPLACED_AUDIO=Replaced previous voice note. Send context or 'no'.
MSG_IDLE_TEXT_HINT=Send me a voice note to start.
MSG_TRANSCODE_ERROR=Could not process that voice note. Re-record and resend.
MSG_LLM_ERROR=Processing failed. Re-record and resend.
# Empty by default — set non-empty if you want a notification when a stale
# awaiting_context state is silently dropped.
MSG_TIMEOUT_DROPPED=
LABEL_TRANSCRIPT=Transcript ({language}):\n
LABEL_SUMMARY=Summary:\n
LABEL_SUGGESTED_REPLY=Suggested reply:\n
